<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <!--设置圆环大小  -->
            <size android:width="26dp" android:height="26dp"/>
            <!-- 边线颜色和宽度 -->
            <stroke android:width="3dp" android:color="@color/color_selected"/>
        </shape>
    </item>
    <item >
        <shape android:shape="oval">
            <!--设置圆环大小  -->
            <size android:width="26dp" android:height="26dp"/>
            <!-- 边线颜色和宽度 -->
            <stroke android:width="12dp" android:color="@android:color/transparent"/>
            <!-- 填充 -->
            <solid android:color="@color/color_selected"/>
        </shape>
    </item>
</layer-list>