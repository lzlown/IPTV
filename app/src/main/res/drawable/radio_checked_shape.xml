<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape xmlns:android="http://schemas.android.com/apk/res/android"
               android:shape="oval">

            <!--设置圆环大小  -->
            <size android:width="26dp" android:height="26dp"></size>
            <!-- 边线颜色和宽度 -->
            <stroke android:width="3dp" android:color="@color/color_selected"></stroke>
        </shape>
    </item>
    <item android:left="3dp" android:right="3dp" android:top="3dp" android:bottom="3dp">
        <shape xmlns:android="http://schemas.android.com/apk/res/android"
               android:shape="oval" >
            <!--设置圆环大小  -->
            <size android:width="26dp" android:height="26dp"></size>
            <!-- 边线颜色和宽度 -->
            <stroke android:width="6dp" android:color="@android:color/transparent"></stroke>
            <!-- 填充 -->
            <solid android:color="@color/color_selected"></solid>
        </shape>
    </item>
</layer-list>